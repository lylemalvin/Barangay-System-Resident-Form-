<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.shape.Circle?>

<VBox spacing="0" xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.sanmarino.barangaysystem.HelloController"
      style="-fx-background-color:#f4f4f4;">

    <HBox alignment="CENTER_LEFT"
          style="-fx-background-color:white; -fx-padding:15 25;">

        <HBox alignment="CENTER_LEFT" spacing="10">
            <Circle radius="25" fill="#148C9E"/>
            <Label text="Brgy. San Marino"
                   style="-fx-font-size:26px; -fx-font-weight:bold;"/>
        </HBox>

        <Pane HBox.hgrow="ALWAYS" maxWidth="150"/>

        <HBox alignment="CENTER" spacing="50">
            <Label text="Announcement" onMouseClicked="#goAnnouncement"
                   style="-fx-font-size:18px; -fx-cursor:hand;"/>
            <Label text="Home" onMouseClicked="#goHome"
                   style="-fx-font-size:18px; -fx-cursor:hand;"/>
            <Label text="Records" onMouseClicked="#goRecords"
                   style="-fx-font-size:18px; -fx-cursor:hand;"/>
            <Label text="About" onMouseClicked="#goAbout"
                   style="-fx-font-size:18px; -fx-cursor:hand;"/>
        </HBox>

        <Pane HBox.hgrow="ALWAYS"/>

        <StackPane>
            <Circle radius="25" fill="#999"/>
            <Label text="PROFILE"
                   style="-fx-font-size:10px; -fx-text-fill:white;"/>
        </StackPane>
    </HBox>

    <VBox spacing="15" style="-fx-padding:20;">

        <HBox alignment="CENTER_LEFT" spacing="15">

            <Label text="Resident"
                   style="-fx-background-color:#148C9E;
                          -fx-text-fill:white;
                          -fx-font-size:22px;
                          -fx-font-weight:bold;
                          -fx-padding:10 40;
                          -fx-background-radius:25;"/>

            <Pane HBox.hgrow="ALWAYS"/>

            <Button text="Add" onAction="#openAddPopup"
                    style="-fx-background-color:#148C9E; -fx-text-fill:white; -fx-background-radius:20; -fx-padding:8 20;"/>

            <Button text="Edit" onAction="#openEditPopup"
                    style="-fx-background-color:#ff9800; -fx-text-fill:white; -fx-background-radius:20; -fx-padding:8 20;"/>

            <Button text="Delete" onAction="#deleteResident"
                    style="-fx-background-color:#f44336; -fx-text-fill:white; -fx-background-radius:20; -fx-padding:8 20;"/>

            <TextField fx:id="searchField"
                       promptText="Search..."
                       style="-fx-background-radius:20; -fx-padding:8 15;"/>

            <ComboBox fx:id="filterBox"
                      promptText="Filter By"/>
        </HBox>

        <TableView fx:id="table" VBox.vgrow="ALWAYS">
            <columns>
                <TableColumn fx:id="idCol" text="ID"/>
                <TableColumn fx:id="lastCol" text="Last Name"/>
                <TableColumn fx:id="middleCol" text="Middle Name"/>
                <TableColumn fx:id="firstCol" text="First Name"/>
                <TableColumn fx:id="suffixCol" text="Suffix"/>
                <TableColumn fx:id="contactCol" text="Contact"/>
                <TableColumn fx:id="emailCol" text="Email"/>
                <TableColumn fx:id="houseCol" text="House Number"/>
                <TableColumn fx:id="streetCol" text="Street"/>
                <TableColumn fx:id="civilCol" text="Civil Status"/>
                <TableColumn fx:id="birthCol" text="Date of Birth"/>
            </columns>
        </TableView>

    </VBox>
</VBox>